{
  "name": "app-people-list",
  "version": "0.2.1",
  "private": true,
  "description": "Micro-frontend that renders a people list from SWAPI",
  "main": "src/index.tsx",
  "scripts": {
    "dev": "npm run dev:webpack",
    "dev:webpack": "webpack serve -c ./webpack.config.js",
    "build": "npm run build:webpack",
    "build:webpack": "tsc && webpack --mode production -c ./webpack.config.js",
    "dev:rspack": "rspack serve -c ./rspack.config.js",
    "build:rspack": "tsc && rspack build -c ./rspack.config.js",
    "dev:vite": "vite -c ./vite.config.js",
    "build:vite": "tsc && vite build -c ./vite.config.js",
    "test": "echo \"no tests yet\"",
    "lint": "oxlint --fix .",
    "format": "oxfmt ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/craigmorrison/example-webpack-module-federation.git"
  },
  "author": "Craig Morrison <hello@craigmorrison.co.uk>",
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@tanstack/react-query": "^5.72.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1"
  }
}
