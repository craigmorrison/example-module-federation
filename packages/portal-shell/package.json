{
  "name": "portal-shell",
  "version": "1.0.0",
  "description": "Host application for the federated portal",
  "main": "index.js",
  "repository": "https://github.com/craigmorrison/example-module-federation.git",
  "author": "Craig Morrison",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "npm run dev:webpack",
    "dev:webpack": "webpack-cli serve -c ./webpack.config.js",
    "build": "npm run build:webpack",
    "build:webpack": "webpack --mode production -c ./webpack.config.js",
    "dev:rspack": "rspack serve -c ./rspack.config.js",
    "build:rspack": "rspack build -c ./rspack.config.js",
    "dev:vite": "vite -c ./vite.config.js",
    "build:vite": "vite build -c ./vite.config.js"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0"
  }
}
