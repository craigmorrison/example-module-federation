{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "rootDirs": [".", "./.react-router/types"],
    "outDir": "build"
  },
  "include": ["app/**/*", "react-router.config.ts", "vite.config.ts"]
}
