{
  "name": "example-module-federation",
  "version": "1.0.0",
  "description": "Cross-bundler Module Federation proof of concept (Webpack, Rspack, Vite)",
  "repository": "https://github.com/craigmorrison/example-module-federation.git",
  "author": "Craig Morrison",
  "license": "MIT",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/*"
  ],
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=!portal-shell-ssr",
    "dev:ssr": "turbo run dev:webpack --filter=app-counter --filter=app-table --filter=app-people-list & turbo run dev --filter=portal-shell-ssr",
    "dev:webpack": "turbo run dev:webpack --filter=!portal-shell-ssr",
    "dev:rspack": "turbo run dev:webpack --filter=app-counter --filter=app-table & turbo run dev:rspack --filter=portal-shell --filter=app-people-list",
    "dev:vite": "turbo run dev:webpack --filter=app-counter --filter=app-table & turbo run dev:vite --filter=portal-shell --filter=app-people-list",
    "build": "turbo run build",
    "build:webpack": "turbo run build:webpack",
    "build:rspack": "turbo run build:rspack",
    "build:vite": "turbo run build:vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "oxlint --fix",
    "*.{js,jsx,ts,tsx,css,md,json}": "oxfmt"
  },
  "devDependencies": {
    "@module-federation/enhanced": "^2.3.0",
    "@swc/core": "^1.15.0",
    "@swc/plugin-emotion": "^14.0.0",
    "@module-federation/vite": "^1.13.0",
    "@rspack/cli": "^1.0.0",
    "@rspack/core": "^1.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "html-webpack-plugin": "^5.6.3",
    "oxfmt": "^0.1.0",
    "oxlint": "^1.0.0",
    "swc-loader": "^0.2.7",
    "jsdom": "^26.0.0",
    "turbo": "^2.0.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0",
    "typescript": "^5.8.3",
    "webpack": "^5.104.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
