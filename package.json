{
  "name": "example-module-federation",
  "version": "1.0.0",
  "description": "Cross-bundler Module Federation proof of concept (Webpack, Rspack, Vite)",
  "repository": "https://github.com/craigmorrison/example-module-federation.git",
  "author": "Craig Morrison",
  "license": "MIT",
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "packages/*"
  ],
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=!portal-shell-ssr",
    "dev:ssr": "turbo run dev --filter=!portal-shell & turbo run dev --filter=portal-shell-ssr",
    "build": "turbo run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "oxlint --fix",
    "*.{js,jsx,ts,tsx,css,md,json}": "oxfmt"
  },
  "overrides": {
    "defu": ">=6.1.5",
    "axios": ">=1.15.0"
  },
  "devDependencies": {
    "@module-federation/enhanced": "^2.3.1",
    "@swc/core": "^1.15.24",
    "@swc/plugin-emotion": "^14.8.0",
    "@module-federation/vite": "^1.14.1",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@vitejs/plugin-react": "^6.0.0",
    "html-webpack-plugin": "^5.6.3",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "swc-loader": "^0.2.7",
    "jsdom": "^26.0.0",
    "turbo": "^2.9.4",
    "vite": "^8.0.8",
    "vitest": "^3.0.0",
    "typescript": "^6.0.2",
    "webpack": "^5.104.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
